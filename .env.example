# Supabase (públicas a propósito, la seguridad la da RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claves de servidor: nunca deben usarse en componentes "use client"
# Podés usar Groq (gratis) o OpenAI
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Supabase service role (solo server): para guardar turnos y consultar horarios
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
