# Supabase (públicas a propósito, la seguridad la da RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (solo server): para guardar turnos y consultar horarios
SUPABASE_SERVICE_ROLE_KEY=

# IA - Podés usar Groq (gratis) o OpenAI
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Twilio (para recordatorios automáticos WhatsApp)
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Google Calendar (para sync de agenda)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
